  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: 0}
    text: "\uB3C4\uC11C\uAD00\uC740 9\uC2DC\uC5D0 \uBB38\uC744 \uB2EB\uB294\uB370..."
