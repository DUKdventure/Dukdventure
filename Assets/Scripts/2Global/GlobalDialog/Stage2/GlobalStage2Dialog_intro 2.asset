  lines:
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: 0}
    text: "\uD070\uC77C\uC774\uC57C! 9\uC2DC\uAC00 \uAC70\uC758 \uB2E4 \uB418\uC5C8\uC5B4..."
