  lines:
  - characterName: "\uAD50\uC218"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uAC70\uAE30 \uB355\uC0C8 \uD559\uC0DD! \uADF8\uB807\uB2E4\uBA74 \uC774
      \uBB38\uC81C\uC5D0 \uB2F5\uC774 \uBB50\uC9C0?"
    imageSize: {x: 450, y: 650}
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: 0}
    text: "\uC74C....\uADF8\uAC8C...\uC5B4....\r\n"
    imageSize: {x: 0, y: 0}
  - characterName: "\uBCF5\uB2E8\uC774"
    characterSprite: {fileID: -6257971620315648974, guid: fde1834d1d1ce9a4fa12058e3d411318, type: 3}
    text: "\uC7A0\uAE50! \uB0B4\uAC00 \uB3C4\uC640\uC904\uAC8C!\r\n"
    imageSize: {x: 500, y: 500}
  - characterName: "\uBCF5\uB2E8\uC774"
    characterSprite: {fileID: -6257971620315648974, guid: fde1834d1d1ce9a4fa12058e3d411318, type: 3}
    text: "\uD558\uC9C0\uB9CC \uADF8\uB0E5 \uC54C\uB824\uC8FC\uBA74 \uC7AC\uBBF8
      \uC5C6\uC9C0.\r\n"
    imageSize: {x: 500, y: 500}
  - characterName: "\uBCF5\uB2E8\uC774"
    characterSprite: {fileID: -6257971620315648974, guid: fde1834d1d1ce9a4fa12058e3d411318, type: 3}
    text: "\uAC04\uB2E8\uD55C \uAC8C\uC784\uC744 \uD1B5\uD574 \uC815\uB2F5\uC744
      \uC54C\uB824\uC904\uAC8C.\r\n"
    imageSize: {x: 500, y: 500}
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: -6257971620315648974, guid: fde1834d1d1ce9a4fa12058e3d411318, type: 3}
    text: "\uC751...? \uAD73\uC774 \uAC8C\uC784\uAE4C\uC9C0 \uD574\uC57C\uD574?"
    imageSize: {x: 0, y: 0}
  - characterName: "\uAD50\uC218"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uB355\uC0C8 \uD559\uC0DD? \uB300\uB2F5 \uC548\uD558\uB098?"
    imageSize: {x: 450, y: 650}
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: -6257971620315648974, guid: fde1834d1d1ce9a4fa12058e3d411318, type: 3}
    text: "\uD5C9...\uD070\uC77C\uC774\uB2E4! \uBE68\uB9AC \uC2DC\uC791\uD558\uC790"
    imageSize: {x: 0, y: 0}
