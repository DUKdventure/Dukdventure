  lines:
  - characterName: "\uAD50\uC218"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uC774\uB807\uAC8C \uD6CC\uB96D\uD55C \uD559\uC0DD\uC774\uB77C\uB2C8!"
    imageSize: {x: 450, y: 650}
  - characterName: "\uAD50\uC218"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uC88B\uC544! \uBB34\uC5C7\uC744 \uBC30\uC6E0\uC9C0?"
    imageSize: {x: 450, y: 650}
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uBC30\uC6C0\uC740 \uD638\uAE30\uC2EC\uC5D0\uC11C \uC2DC\uC791\uB418\uC5B4"
    imageSize: {x: 0, y: 0}
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uC554\uAE30\uB97C \uD1B5\uD574 \uC2B5\uB4DD\uB418\uC5B4"
    imageSize: {x: 0, y: 0}
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uC2E4\uD328\uB97C \uD1B5\uD574 \uC9C4\uC9DC \uAE68\uB2EC\uC74C\uC774
