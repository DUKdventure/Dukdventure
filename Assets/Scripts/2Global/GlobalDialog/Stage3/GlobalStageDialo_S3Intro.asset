  lines:
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uC5EC\uAE30 \uC774 \uC2E0\uBE44\uD55C \uACF3\uC740 \uBB50\uC9C0?"
    imageSize: {x: 0, y: 0}
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uC5B4?! \uBAB8\uC774 \uBE68\uB824 \uB4E4\uC5B4\uAC00\uACE0 \uC788\uC5B4...!!!\r\n"
    imageSize: {x: 0, y: 0}
  - characterName: "\uC2A4\uD551\uD06C\uC2A4"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uD760...\uB355\uC131\uC5EC\uB300 \uD559\uC0DD\uC774\uAD6C\uB098!\r\n"
    imageSize: {x: 0, y: 0}
  - characterName: "\uC2A4\uD551\uD06C\uC2A4"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uD568\uBD80\uB85C \uC774\uACF3\uC5D0 \uB4E4\uC5B4\uC624\uB2E4\uB2C8 \uC6A9\uC11C\uD560
      \uC218 \uC5C6\uB2E4!\r\n"
    imageSize: {x: 0, y: 0}
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uD55C\uBC88\uB9CC \uAE30\uD68C\uB97C \uC8FC\uC138\uC694!"
    imageSize: {x: 0, y: 0}
  - characterName: "\uB355\uC0C8"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uC800 \uC790\uB8CC\uC870\uC0AC \uC81C\uCD9C\uD574\uC57C\uD574\uC694..."
    imageSize: {x: 0, y: 0}
  - characterName: "\uC2A4\uD551\uD06C\uC2A4"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uC88B\uB2E4!"
    imageSize: {x: 0, y: 0}
  - characterName: "\uC2A4\uD551\uD06C\uC2A4"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uB0B4\uAC00 \uB0B4\uB294 \uBB38\uC81C\uC758 \uB2F5\uC744 \uBAA8\uB450
      \uB9DE\uCD94\uB3C4\uB85D!\r\n"
    imageSize: {x: 0, y: 0}
  - characterName: "\uC2A4\uD551\uD06C\uC2A4"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: " \uAE30\uD68C\uB294 \uC624\uC9C1 \uD55C \uBC88! \uD2C0\uB9AC\uBA74 \uC774
      \uACF3\uC5D0 \uC601\uC6D0\uD788 \uAC07\uD788\uB294 \uAC70\uC57C \r\n"
    imageSize: {x: 0, y: 0}
  - characterName: "\uC2A4\uD551\uD06C\uC2A4"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: " \uAE30\uD68C\uB294 \uC624\uC9C1 \uD55C \uBC88! \uD2C0\uB9AC\uBA74 \uC774
      \uACF3\uC5D0 \uC601\uC6D0\uD788 \uAC07\uD788\uB294 \uAC70\uC57C \r\n"
    imageSize: {x: 0, y: 0}
  - characterName: "\uC2A4\uD551\uD06C\uC2A4"
    characterSprite: {fileID: -7376690901357878632, guid: 1c36ab2264587474c8292cf004ed2b60, type: 3}
    text: "\uADF8\uB7FC \uAC8C\uC784\uC744 \uC2DC\uC791\uD558\uC9C0. "
    imageSize: {x: 0, y: 0}
